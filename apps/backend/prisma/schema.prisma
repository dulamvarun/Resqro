datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Category {
  id        String     @id @default(uuid())
  name      String
  sortOrder Int
  items     MenuItem[]
}

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  price       Float
  description String
  isVeg       Boolean
  imageId     String?     // Cloudinary ID or URL
  isAvailable Boolean     @default(true)
  isChefsPick Boolean     @default(false)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
}

model Order {
  id          String      @id @default(uuid())
  tableId     String
  status      OrderStatus @default(RECEIVED)
  totalAmount Float
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model OrderItem {
  id             String          @id @default(uuid())
  orderId        String
  menuItemId     String
  quantity       Int
  customizations String?         // Free-text notes
  status         OrderItemStatus @default(PENDING)
  order          Order           @relation(fields: [orderId], references: [id])
  menuItem       MenuItem        @relation(fields: [menuItemId], references: [id])
}

enum OrderStatus {
  RECEIVED
  CONFIRMED
  READY
  SERVED
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  READY
  SERVED
}
